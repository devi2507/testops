# TestOps Backend Environment Configuration

# MongoDB Atlas connection string
# Example: mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017

# Groq API Key for AI-powered analysis
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# CORS allowed origins (comma-separated for multiple)
# Development: * (allow all)
# Production: https://your-frontend.com, https://www.your-frontend.com
ALLOWED_ORIGINS=*
