# TestOps Backend Environment Configuration

# MongoDB Atlas connection string
# Example: mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017

# Groq API Key for AI-powered analysis
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# CORS allowed origins (comma-separated for multiple)
# Development: * (allow all)
# Production: https://your-frontend.com, https://www.your-frontend.com
ALLOWED_ORIGINS=*

# Email Configuration (for team workspace invitations)
# SMTP Host - Gmail: smtp.gmail.com, Outlook: smtp-mail.outlook.com
SMTP_HOST=smtp.gmail.com

# SMTP Port - Gmail/Outlook: 587 (TLS)
SMTP_PORT=587

# SMTP Username (your email address)
# For Gmail, use your full email: user@gmail.com
# For Gmail with 2FA, create an "App Password": https://support.google.com/accounts/answer/185833
SMTP_USER=your-email@gmail.com

# SMTP Password or App Password
SMTP_PASSWORD=your-app-password-here

# Email sender display name and address
EMAIL_SENDER=noreply@testops.com

# Frontend application URL (for links in invitation emails)
APP_URL=http://localhost:3000
